# Example .env file
# the twitch channel the bot will operate in
PHANTOMBOT_CHANNEL=LOTV
# the name of the bot owner, who has administrator privileges to the bot
PHANTOMBOT_OWNER=Ell

# the twitch developer application client id
PHANTOMBOT_CLIENTID=setme
# the twitch developer application client secret
PHANTOMBOT_CLIENTSECRET=setme
# the username to login to the panel.

PHANTOMBOT_PANELUSER=lily
# the password to login to the panel
# PHANTOMBOT_PANELPASSWORD=stronk

# the timezone for timestamps in the log. must be a valid iana time zone database name
PHANTOMBOT_LOGTIMEZONE=Europe/Berlin